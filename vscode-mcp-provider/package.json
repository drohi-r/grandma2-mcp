{
  "name": "ma2-onpc-mcp",
  "displayName": "MA2 Agent",
  "description": "Registers the MA2 Agent MCP server for AI assistants via MCP stdio transport.",
  "version": "1.0.0",
  "engines": {
    "vscode": ">=1.80.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "mcpServerDefinitionProviders": [
      {
        "id": "ma2-onpc-mcp.mcp-servers",
        "label": "MA2 Agent Servers"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0"
  },
  "dependencies": {}
}
