# grandMA2 console connection
GMA_HOST=
GMA_USER=
GMA_PASSWORD=

# OAuth 2.1 scope enforcement (stub — no external IdP required)
# Set to a tier shorthand or space-separated explicit scopes:
#   tier:0  → gma2:discover, gma2:state:read             (Guest / rights=0)
#   tier:1  → + gma2:playback:go, gma2:executor:control  (Operator / rights=1)
#   tier:2  → + gma2:programmer:write, gma2:preset:update (Presets / rights=2)
#   tier:3  → + gma2:cue:store, gma2:sequence:edit, ...  (Programmer / rights=3)
#   tier:4  → + gma2:setup:console, gma2:patch:write, ... (Tech Director / rights=4)
#   tier:5  → + gma2:user:manage, gma2:show:load, ...    (Administrator / rights=5)
# Or use explicit scopes: GMA_SCOPE="gma2:playback:go gma2:executor:control"
GMA_SCOPE=tier:3

# Set to "1" to bypass all scope checks (development/testing only)
# GMA_AUTH_BYPASS=1

# Passwords for bootstrap_console_users.py (change before network deployment!)
GMA_ADMIN_PASSWORD=admin
GMA_OPERATOR_PASSWORD=operator
GMA_PRESETS_PASSWORD=presets
GMA_PROGRAMMER_PASSWORD=programmer
GMA_TECH_DIR_PASSWORD=techdir
GMA_GUEST_PASSWORD=

# GitHub Models Embedding Provider (for RAG vector search)
# Get a PAT with models:read scope at https://github.com/settings/tokens
GITHUB_MODELS_TOKEN=
RAG_EMBED_MODEL=openai/text-embedding-3-small
RAG_EMBED_DIMENSIONS=1536
